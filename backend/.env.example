# Copy to .env and set your values. No quotes.

# Server port (default 9001)
# PORT=9001

# Supabase (API connection - from Supabase Dashboard)
# Project URL: Settings > API > Project URL
# SUPABASE_URL=https://xxxxx.supabase.co
# Service role key: Settings > API > Project API keys > service_role secret (Reveal & copy)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# JWT secret for auth tokens (change in production)
# JWT_SECRET=your-random-secret-key
# FFMPEG_PATH=C:\path\to\ffmpeg\bin\ffmpeg.exe
# Optional: full path to Python that has openai-whisper (if "python" / "py" not on PATH)
# WHISPER_PATH=C:\Users\...\Python313\python.exe
# Or just: WHISPER_CMD=python
# Live transcription (any browser): get a key at https://deepgram.com
# DEEPGRAM_API_KEY=your_api_key_here
# Optional: DEEPGRAM_MODEL=nova-3 (default). DEEPGRAM_LANGUAGE=hi for Hindi/Hinglish (default), en for English only, multi for 10-language auto.
